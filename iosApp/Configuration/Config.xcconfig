// storeA configuration (full app, includes Invoices).
TEAM_ID=

PRODUCT_NAME=KmpProj
PRODUCT_BUNDLE_IDENTIFIER=com.isharaw.kmpproj.storea

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// Drives the Kotlin framework build phase (-Pstore=$GRADLE_STORE).
GRADLE_STORE=storeA
// Per-feature flags: compile the Swift UI for the features storeA ships (cart, invoices, orders).
SWIFT_ACTIVE_COMPILATION_CONDITIONS=STORE_HAS_CART STORE_HAS_INVOICES STORE_HAS_ORDERS
