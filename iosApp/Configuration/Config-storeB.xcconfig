// storeB configuration (login, cart, settings, rebate — no Invoices/Orders).
TEAM_ID=

PRODUCT_NAME=KmpProj
PRODUCT_BUNDLE_IDENTIFIER=com.isharaw.kmpproj.storeb

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// Drives the Kotlin framework build phase (-Pstore=$GRADLE_STORE).
GRADLE_STORE=storeB
// storeB ships cart only (of the flagged features); invoices/orders code is excluded.
SWIFT_ACTIVE_COMPILATION_CONDITIONS=STORE_HAS_CART
