// storeB configuration (no Invoices feature).
TEAM_ID=

PRODUCT_NAME=KmpProj
PRODUCT_BUNDLE_IDENTIFIER=com.isharaw.kmpproj.storeb

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// Drives the Kotlin framework build phase (-Pstore=$GRADLE_STORE).
GRADLE_STORE=storeB
// No STORE_HAS_INVOICES flag -> invoices code is excluded from compilation.
SWIFT_ACTIVE_COMPILATION_CONDITIONS=
