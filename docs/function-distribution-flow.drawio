        <mxCell id="functions" value="Functions shown / hidden for THIS user&#10;(tabs, buttons, data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="760" width="260" height="60" as="geometry" />
