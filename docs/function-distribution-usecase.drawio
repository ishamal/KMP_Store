<mxfile host="app.diagrams.net" type="device">
  <diagram id="usecase-1" name="Use Case - Function Distribution">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Use Case Diagram — Function Distribution Across Apps" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <!-- BUILD-TIME boundary -->
        <mxCell id="bBuild" value="Platform — Build time" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=2;fillColor=none;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="55" width="330" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ucConfigure" value="Select functions&#10;for each app&#10;(Store Manifest)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="75" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="actorEng" value="Release / Build&#10;Engineer" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="360" y="70" width="40" height="70" as="geometry" />
        </mxCell>

        <!-- RUN-TIME boundary (the app) -->
        <mxCell id="bApp" value="Store App — Run time (one installed app)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=2;fillColor=none;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="300" y="190" width="480" height="540" as="geometry" />
        </mxCell>

        <!-- Actors -->
        <mxCell id="actorUSBL" value="Full-access User&#10;(USBL)" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="40" height="70" as="geometry" />
        </mxCell>
        <mxCell id="actorCABL" value="Restricted User&#10;(CABL)" style="shape=umlActor;verticalLabelPosition=bottom;labelPosition=center;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="70" y="560" width="40" height="70" as="geometry" />
        </mxCell>

        <!-- Use cases -->
        <mxCell id="ucLogin" value="Log in" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="330" y="220" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ucOrders" value="View Orders" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="330" y="310" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ucInvoices" value="View Invoices" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="570" y="310" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ucExport" value="Export Invoices" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="570" y="410" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ucRebates" value="View Rebates" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="330" y="410" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ucSettings" value="Manage Settings" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="450" y="510" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ucReset" value="Reset Password" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="450" y="600" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Engineer association -->
        <mxCell id="aEng" style="endArrow=none;html=1;" edge="1" parent="1" source="actorEng" target="ucConfigure">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- USBL associations -->
        <mxCell id="u1" style="endArrow=none;html=1;" edge="1" parent="1" source="actorUSBL" target="ucLogin"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u2" style="endArrow=none;html=1;" edge="1" parent="1" source="actorUSBL" target="ucOrders"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u3" style="endArrow=none;html=1;" edge="1" parent="1" source="actorUSBL" target="ucInvoices"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u4" style="endArrow=none;html=1;" edge="1" parent="1" source="actorUSBL" target="ucExport"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u5" style="endArrow=none;html=1;" edge="1" parent="1" source="actorUSBL" target="ucSettings"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="u6" style="endArrow=none;html=1;" edge="1" parent="1" source="actorUSBL" target="ucReset"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- CABL associations (restricted: no Orders, no Export) -->
        <mxCell id="c1" style="endArrow=none;html=1;" edge="1" parent="1" source="actorCABL" target="ucLogin"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c2" style="endArrow=none;html=1;" edge="1" parent="1" source="actorCABL" target="ucInvoices"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3" style="endArrow=none;html=1;" edge="1" parent="1" source="actorCABL" target="ucSettings"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c4" style="endArrow=none;html=1;" edge="1" parent="1" source="actorCABL" target="ucReset"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- include: every function requires Log in -->
        <mxCell id="inc1" value="&lt;&lt;include&gt;&gt;" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="ucOrders" target="ucLogin"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="inc2" value="&lt;&lt;include&gt;&gt;" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="ucInvoices" target="ucLogin"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- extend: Export is an optional, capability-gated extension of View Invoices -->
        <mxCell id="ext1" value="&lt;&lt;extend&gt;&gt;&#10;(capability-gated)" style="endArrow=open;dashed=1;html=1;fontSize=10;" edge="1" parent="1" source="ucExport" target="ucInvoices"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Legend&#10;• Stick figure = Actor (a user/role)&#10;• Oval = Use case (a function)&#10;• Solid line = actor can use it&#10;• &lt;&lt;include&gt;&gt; = always required (Log in)&#10;• &lt;&lt;extend&gt;&gt; = shown only if the user's capability allows&#10;• Which ovals exist in an app = chosen at build time (Store Manifest)" style="text;html=1;align=left;verticalAlign=top;spacing=6;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="240" height="120" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
